DATABASE_URL="postgresql://ta_admin:ta_admin_password@localhost:5432/ta_management?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
APP_TIMEZONE="Asia/Baku"
APP_DEFAULT_LOCALE="fa-IR"
# Local dev defaults point at the Mailpit container from docker-compose.yml
# (SMTP on 1025, web UI at http://localhost:8025). Point at a real SMTP server in production.
EMAIL_FROM="noreply@example.edu"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
# Local dev defaults point at the MinIO container from docker-compose.yml.
# In production, point these at a real S3 bucket/credentials instead.
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="ta_minio_admin"
S3_SECRET_ACCESS_KEY="ta_minio_password"
S3_BUCKET="ta-management-dev"
AUTH_ENCRYPTION_KEY="replace-with-32-byte-random-secret-for-2fa"
AUTH_REQUIRE_EMAIL_VERIFICATION="false"
AUTH_ENFORCE_2FA_FOR_STAFF="false"
AUTH_TOTP_ISSUER="TA Management System"
AUTH_KEYCLOAK_ID=""
AUTH_KEYCLOAK_SECRET=""
AUTH_KEYCLOAK_ISSUER=""
