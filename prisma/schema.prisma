generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  STUDENT
  PROFESSOR
  EDUCATION_ADMIN
  SYSTEM_ADMIN
}

enum UserStatus {
  PENDING_EMAIL
  ACTIVE
  SUSPENDED
  DELETED
}

enum SemesterStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CourseOfferingStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum CourseRoleType {
  STUDENT
  TA
  HEAD_TA
  PROFESSOR
  EDUCATION_ADMIN
}

enum TAOpportunityStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum RequestedTARole {
  TA
  HEAD_TA
  EITHER
}

enum TAApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_INVITED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ReviewDecision {
  PENDING
  APPROVE
  REJECT
  SHORTLIST
  INTERVIEW
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FileVisibility {
  PRIVATE
  COURSE_STAFF
  ADMIN_ONLY
  PUBLIC
}

enum OfficeHourStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum ExportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ExportFormat {
  CSV
  XLSX
  PDF
}

enum GradeVisibility {
  STAFF_ONLY
  STUDENT_PRIVATE
  PUBLISHED
}

enum GradeRecordStatus {
  DRAFT
  FINALIZED
  PUBLISHED
  LOCKED
}

enum GradeImportStatus {
  QUEUED
  VALIDATING
  IMPORTED
  PARTIAL_FAILED
  FAILED
  ROLLED_BACK
}

enum CertificateRequestStatus {
  DRAFT
  SUBMITTED
  PROFESSOR_APPROVED
  EDUCATION_APPROVED
  ISSUED
  REJECTED
  REVOKED
}

enum CertificateRole {
  TA
  HEAD_TA
}

enum PollType {
  CLASS_TIME
  OFFICE_HOUR_TIME
  MAKEUP_CLASS
  PROJECT_SESSION
  CUSTOM
}

enum PollStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum MessageThreadType {
  COURSE_GENERAL
  PRIVATE_STAFF
  GRADE_APPEAL
  OFFICE_HOUR
  ADMIN_SUPPORT
  TA_TEAM
  COURSE_WIDE
}

enum MessageStatus {
  SENT
  EDITED
  DELETED
}

enum SurveyType {
  TA_MIDTERM
  TA_FINAL
  PROFESSOR_EVALUATION
  COURSE_FEEDBACK
  CUSTOM
}

enum QuestionType {
  RATING
  TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  BOOLEAN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum NotificationType {
  APPLICATION_STATUS
  MESSAGE
  OFFICE_HOUR
  SURVEY
  CERTIFICATE
  GRADE
  ANNOUNCEMENT
  SECURITY
  DEADLINE
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  PUBLISH
  ISSUE
  REVOKE
}

enum SecurityEventType {
  LOGIN_FAILED
  LOGIN_SUCCESS
  PASSWORD_RESET_REQUESTED
  PASSWORD_CHANGED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_FAILED
  RATE_LIMITED
  PERMISSION_DENIED
  SUSPICIOUS_EXPORT
}

model User {
  id                      String                     @id @default(cuid())
  name                    String?
  email                   String                     @unique
  emailVerified           DateTime?
  passwordHash            String?
  passwordChangedAt       DateTime?
  failedLoginCount        Int                        @default(0)
  lockedUntil             DateTime?
  mustChangePassword      Boolean                    @default(false)
  twoFactorEnabled        Boolean                    @default(false)
  twoFactorRequired       Boolean                    @default(false)
  image                   String?
  globalRole              GlobalRole                 @default(STUDENT)
  status                  UserStatus                 @default(PENDING_EMAIL)
  locale                  String                     @default("fa-IR")
  timezone                String                     @default("Asia/Tehran")
  lastLoginAt             DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  deletedAt               DateTime?
  studentProfile          StudentProfile?
  professorProfile        ProfessorProfile?
  accounts                Account[]
  sessions                Session[]
  twoFactorMethods        TwoFactorMethod[]
  uploadedFiles           UploadedFile[]             @relation("UserUploadedFiles")
  courseEnrollments       CourseEnrollment[]         @relation("StudentEnrollments")
  courseRoles             CourseRoleAssignment[]     @relation("CourseRoleAssignee")
  courseRolesAssigned     CourseRoleAssignment[]     @relation("CourseRoleAssignedBy")
  courseRolesRevoked      CourseRoleAssignment[]     @relation("CourseRoleRevokedBy")
  createdOpportunities    TAOpportunity[]            @relation("OpportunityCreator")
  applications            TAApplication[]            @relation("ApplicantApplications")
  applicationReviews      ApplicationReview[]        @relation("ApplicationReviewer")
  interviews              Interview[]                @relation("InterviewApplicant")
  conductedInterviews     Interview[]                @relation("InterviewInterviewer")
  resumeItems             ResumeItem[]
  createdOfficeHours      OfficeHourSession[]        @relation("OfficeHourCreator")
  hostedOfficeHours       OfficeHourSession[]        @relation("OfficeHourHost")
  officeHourRegistrations OfficeHourRegistration[]   @relation("OfficeHourRegistrant")
  officeHourQueueEntries  OfficeHourQueueEntry[]     @relation("OfficeHourQueueStudent")
  rosterExports           ClassRosterExport[]
  gradeCategories         GradeCategory[]            @relation("GradeCategoryCreator")
  gradeItems              GradeItem[]                @relation("GradeItemCreator")
  assignedGradeItems      GradeItem[]                @relation("GradeItemAssignee")
  gradeRecords            GradeRecord[]              @relation("StudentGradeRecords")
  editedGradeRecords      GradeRecord[]              @relation("GradeRecordEditor")
  gradeChangeLogs         GradeChangeLog[]           @relation("GradeChangedBy")
  regradeRequests         RegradeRequest[]           @relation("RegradeRequester")
  regradeResponses        RegradeRequest[]           @relation("RegradeResponder")
  gradeImportBatches      GradeImportBatch[]
  exportJobs              ExportJob[]
  certificateRequests     CertificateRequest[]       @relation("CertificateRequester")
  professorApprovals      CertificateRequest[]       @relation("CertificateProfessorApprover")
  educationApprovals      CertificateRequest[]       @relation("CertificateEducationApprover")
  certificateRevocations  TACertificate[]            @relation("CertificateRevokedBy")
  createdPolls            AvailabilityPoll[]         @relation("PollCreator")
  pollVotes               PollVote[]
  createdThreads          MessageThread[]            @relation("ThreadCreator")
  threadParticipants      MessageThreadParticipant[]
  messages                Message[]
  createdSurveys          Survey[]                   @relation("SurveyCreator")
  surveyAnswers           SurveyAnswer[]
  professorEvaluations    ProfessorEvaluation[]      @relation("ProfessorEvaluationStudent")
  taEvaluations           TAEvaluation[]             @relation("TAEvaluationStudent")
  announcements           Announcement[]             @relation("AnnouncementCreator")
  academicEvents          AcademicCalendarEvent[]    @relation("AcademicEventCreator")
  assignedTasks           Task[]                     @relation("TaskAssignee")
  createdTasks            Task[]                     @relation("TaskCreator")
  taskSubmissions         TaskSubmission[]           @relation("TaskSubmitter")
  assignmentSubmissions   AssignmentSubmission[]     @relation("AssignmentSubmitter")
  uploadedCourseMaterials CourseMaterial[]           @relation("CourseMaterialUploader")
  activityReports         ActivityReport[]
  notifications           Notification[]
  auditLogs               AuditLog[]                 @relation("AuditActor")
  securityEvents          SecurityEvent[]
  professorOfferings      CourseOffering[]           @relation("OfferingProfessor")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model TwoFactorMethod {
  id              String    @id @default(cuid())
  userId          String
  label           String
  encryptedSecret String
  recoveryHash    String?
  enabledAt       DateTime  @default(now())
  lastUsedAt      DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StudentProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  studentNumber String      @unique
  departmentId  String?
  entryYear     Int?
  degreeLevel   String?
  gpa           Decimal?    @db.Decimal(4, 2)
  bio           String?     @db.Text
  githubUrl     String?
  linkedinUrl   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
}

model ProfessorProfile {
  id             String      @id @default(cuid())
  userId         String      @unique
  departmentId   String?
  academicRank   String?
  officeLocation String?
  publicBio      String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
}

model Department {
  id             String                  @id @default(cuid())
  name           String
  code           String                  @unique
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  students       StudentProfile[]
  professors     ProfessorProfile[]
  courses        Course[]
  announcements  Announcement[]
  academicEvents AcademicCalendarEvent[]
}

model Semester {
  id              String                  @id @default(cuid())
  title           String
  code            String                  @unique
  startsAt        DateTime
  endsAt          DateTime
  status          SemesterStatus          @default(DRAFT)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  courseOfferings CourseOffering[]
  academicEvents  AcademicCalendarEvent[]
}

model Course {
  id           String           @id @default(cuid())
  departmentId String?
  code         String           @unique
  title        String
  units        Int              @default(3)
  description  String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  offerings    CourseOffering[]
}

model CourseOffering {
  id                   String                  @id @default(cuid())
  courseId             String
  semesterId           String
  professorId          String
  section              String?
  capacity             Int?
  status               CourseOfferingStatus    @default(DRAFT)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  course               Course                  @relation(fields: [courseId], references: [id], onDelete: Restrict)
  semester             Semester                @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  professor            User                    @relation("OfferingProfessor", fields: [professorId], references: [id], onDelete: Restrict)
  enrollments          CourseEnrollment[]
  roles                CourseRoleAssignment[]
  opportunities        TAOpportunity[]
  officeHours          OfficeHourSession[]
  rosterExports        ClassRosterExport[]
  gradeCategories      GradeCategory[]
  gradeItems           GradeItem[]
  gradeImportBatches   GradeImportBatch[]
  exportJobs           ExportJob[]
  certificateRequests  CertificateRequest[]
  availabilityPolls    AvailabilityPoll[]
  messageThreads       MessageThread[]
  surveys              Survey[]
  professorEvaluations ProfessorEvaluation[]
  taEvaluations        TAEvaluation[]
  announcements        Announcement[]
  academicEvents       AcademicCalendarEvent[]
  tasks                Task[]
  activityReports      ActivityReport[]
  materials            CourseMaterial[]

  // section is nullable, and Postgres treats each NULL as distinct in a
  // plain unique constraint, so this alone would let two offerings with
  // section = NULL collide. The real uniqueness lives in a raw-SQL
  // functional index (course_offering_unique, keyed on COALESCE(section,'')).
  @@index([semesterId, status])
  @@index([professorId])
  @@index([courseId, semesterId, professorId])
}

model CourseEnrollment {
  id               String         @id @default(cuid())
  courseOfferingId String
  studentId        String
  source           String         @default("manual")
  enrolledAt       DateTime       @default(now())
  droppedAt        DateTime?
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  student          User           @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  // Active-enrollment uniqueness is a partial unique index
  // (course_enrollment_active_unique, WHERE "droppedAt" IS NULL), not a
  // plain constraint here, so drop/re-enroll history stays queryable
  // instead of collapsing into one row (same pattern as CourseRoleAssignment).
  @@index([courseOfferingId, studentId])
  @@index([studentId])
}

model CourseRoleAssignment {
  id               String         @id @default(cuid())
  courseOfferingId String
  userId           String
  role             CourseRoleType
  permissionsJson  Json?
  assignedById     String?
  assignmentSource String         @default("manual")
  note             String?        @db.Text
  activeFrom       DateTime       @default(now())
  activeUntil      DateTime?
  revokedAt        DateTime?
  revokedById      String?
  revokeReason     String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  user             User           @relation("CourseRoleAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy       User?          @relation("CourseRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  revokedBy        User?          @relation("CourseRoleRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  // No @@unique here on purpose: a course/user/role triple must be allowed to
  // repeat over time (assign -> revoke -> reassign) without losing history.
  // A partial unique index enforcing "only one active row" is added via raw
  // SQL in the integrity-constraints migration instead.
  @@index([courseOfferingId, role, revokedAt])
  @@index([userId, revokedAt])
  @@index([assignedById])
}

model TAOpportunity {
  id               String              @id @default(cuid())
  courseOfferingId String
  createdById      String
  title            String
  description      String              @db.Text
  requiredTAs      Int                 @default(1)
  needsHeadTA      Boolean             @default(false)
  requirements     String              @db.Text
  selectionRubric  Json?
  formConfigJson   Json?
  opensAt          DateTime?
  deadline         DateTime
  status           TAOpportunityStatus @default(DRAFT)
  publishedAt      DateTime?
  closedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  courseOffering   CourseOffering      @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User                @relation("OpportunityCreator", fields: [createdById], references: [id], onDelete: Restrict)
  applications     TAApplication[]

  @@index([courseOfferingId, status])
  @@index([deadline])
}

model TAApplication {
  id              String              @id @default(cuid())
  opportunityId   String
  applicantId     String
  requestedRole   RequestedTARole
  motivationText  String              @db.Text
  resumeFileId    String?             @unique
  customFieldsJson Json?
  status          TAApplicationStatus @default(SUBMITTED)
  score           Decimal?            @db.Decimal(5, 2)
  rejectionReason String?             @db.Text
  submittedAt     DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  opportunity     TAOpportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  applicant       User                @relation("ApplicantApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  resumeFile      UploadedFile?       @relation("ApplicationResumeFile", fields: [resumeFileId], references: [id], onDelete: SetNull)
  reviews         ApplicationReview[]
  interviews      Interview[]

  @@unique([opportunityId, applicantId])
  @@index([applicantId, status])
}

model ApplicationReview {
  id            String         @id @default(cuid())
  applicationId String
  reviewerId    String
  decision      ReviewDecision @default(PENDING)
  score         Decimal?       @db.Decimal(5, 2)
  internalNote  String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  application   TAApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer      User           @relation("ApplicationReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@unique([applicationId, reviewerId])
  @@index([reviewerId])
}

model Interview {
  id            String          @id @default(cuid())
  applicationId String
  applicantId   String
  interviewerId String
  startsAt      DateTime
  endsAt        DateTime
  location      String?
  meetingUrl    String?
  status        InterviewStatus @default(SCHEDULED)
  notes         String?         @db.Text
  score         Decimal?        @db.Decimal(5, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  application   TAApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicant     User            @relation("InterviewApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  interviewer   User            @relation("InterviewInterviewer", fields: [interviewerId], references: [id], onDelete: Restrict)

  @@index([applicationId])
  @@index([startsAt])
}

model ResumeItem {
  id          String    @id @default(cuid())
  userId      String
  title       String
  itemType    String
  description String?   @db.Text
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UploadedFile {
  id                   String                @id @default(cuid())
  ownerId              String
  originalName         String
  storageKey           String                @unique
  mimeType             String
  sizeBytes            Int
  checksumSha256       String?
  visibility           FileVisibility        @default(PRIVATE)
  createdAt            DateTime              @default(now())
  deletedAt            DateTime?
  owner                User                  @relation("UserUploadedFiles", fields: [ownerId], references: [id], onDelete: Cascade)
  applicationResume    TAApplication?        @relation("ApplicationResumeFile")
  certificateTemplate  CertificateTemplate?  @relation("CertificateTemplateFile")
  certificatePdf       TACertificate?        @relation("CertificatePdfFile")
  taskSubmission       TaskSubmission?       @relation("TaskSubmissionFile")
  assignmentSubmission AssignmentSubmission? @relation("AssignmentSubmissionFile")
  courseMaterial       CourseMaterial?       @relation("CourseMaterialFile")

  @@index([ownerId])
}

model CourseMaterial {
  id               String         @id @default(cuid())
  courseOfferingId String
  uploadedById     String
  fileId           String         @unique
  title            String?
  createdAt        DateTime       @default(now())
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  uploadedBy       User           @relation("CourseMaterialUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  file             UploadedFile   @relation("CourseMaterialFile", fields: [fileId], references: [id], onDelete: Restrict)

  @@index([courseOfferingId, createdAt])
}

model OfficeHourSession {
  id               String                   @id @default(cuid())
  courseOfferingId String
  createdById      String
  hostId           String
  title            String
  description      String?                  @db.Text
  startsAt         DateTime
  endsAt           DateTime
  meetingUrl       String?
  location         String?
  capacity         Int?
  status           OfficeHourStatus         @default(SCHEDULED)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  courseOffering   CourseOffering           @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User                     @relation("OfficeHourCreator", fields: [createdById], references: [id], onDelete: Restrict)
  host             User                     @relation("OfficeHourHost", fields: [hostId], references: [id], onDelete: Restrict)
  registrations    OfficeHourRegistration[]
  queueEntries     OfficeHourQueueEntry[]

  @@index([courseOfferingId, startsAt])
  @@index([hostId, startsAt])
}

model OfficeHourRegistration {
  id           String            @id @default(cuid())
  sessionId    String
  studentId    String
  registeredAt DateTime          @default(now())
  attendedAt   DateTime?
  session      OfficeHourSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student      User              @relation("OfficeHourRegistrant", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
}

enum OfficeHourQueueStatus {
  WAITING
  CALLED
  DONE
  LEFT
}

model OfficeHourQueueEntry {
  id        String                @id @default(cuid())
  sessionId String
  studentId String
  joinedAt  DateTime              @default(now())
  calledAt  DateTime?
  status    OfficeHourQueueStatus @default(WAITING)
  session   OfficeHourSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User                  @relation("OfficeHourQueueStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId, status, joinedAt])
}

model ClassRosterExport {
  id               String         @id @default(cuid())
  courseOfferingId String
  requestedById    String
  format           ExportFormat
  status           ExportStatus   @default(QUEUED)
  fileKey          String?
  rowCount         Int            @default(0)
  errorMessage     String?        @db.Text
  createdAt        DateTime       @default(now())
  completedAt      DateTime?
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  requestedBy      User           @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([courseOfferingId, createdAt])
  @@index([requestedById])
}

model GradeCategory {
  id               String          @id @default(cuid())
  courseOfferingId String
  createdById      String
  name             String
  weight           Decimal         @db.Decimal(5, 2)
  maxScore         Decimal         @db.Decimal(6, 2)
  visibility       GradeVisibility @default(STAFF_ONLY)
  lockedAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  courseOffering   CourseOffering  @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User            @relation("GradeCategoryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items            GradeItem[]

  @@unique([courseOfferingId, name])
  @@index([courseOfferingId])
}

model GradeItem {
  id               String                 @id @default(cuid())
  courseOfferingId String
  categoryId       String
  createdById      String
  assigneeId       String?
  title            String
  maxScore         Decimal                @db.Decimal(6, 2)
  dueAt            DateTime?
  visibility       GradeVisibility        @default(STAFF_ONLY)
  lockedAt         DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  courseOffering   CourseOffering         @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  category         GradeCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("GradeItemCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee         User?                  @relation("GradeItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  records          GradeRecord[]
  submissions      AssignmentSubmission[]

  @@unique([courseOfferingId, title])
  @@index([categoryId])
  @@index([assigneeId])
}

model GradeRecord {
  id              String            @id @default(cuid())
  gradeItemId     String
  studentId       String
  score           Decimal           @db.Decimal(6, 2)
  feedback        String?           @db.Text
  status          GradeRecordStatus @default(DRAFT)
  editedById      String
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  gradeItem       GradeItem         @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  student         User              @relation("StudentGradeRecords", fields: [studentId], references: [id], onDelete: Cascade)
  editedBy        User              @relation("GradeRecordEditor", fields: [editedById], references: [id], onDelete: Restrict)
  changeLogs      GradeChangeLog[]
  regradeRequests RegradeRequest[]

  @@unique([gradeItemId, studentId])
  @@index([studentId, status])
}

enum RegradeRequestStatus {
  OPEN
  APPROVED
  REJECTED
}

model RegradeRequest {
  id            String               @id @default(cuid())
  gradeRecordId String
  studentId     String
  reason        String               @db.Text
  status        RegradeRequestStatus @default(OPEN)
  response      String?              @db.Text
  respondedById String?
  resolvedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  gradeRecord   GradeRecord          @relation(fields: [gradeRecordId], references: [id], onDelete: Cascade)
  student       User                 @relation("RegradeRequester", fields: [studentId], references: [id], onDelete: Cascade)
  respondedBy   User?                @relation("RegradeResponder", fields: [respondedById], references: [id], onDelete: SetNull)

  // App-level check in createRegradeRequest already blocks a second OPEN
  // request per grade/student; this partial unique index is the DB-level
  // backstop against the race between the check and the insert.
  @@index([gradeRecordId])
  @@index([studentId, status])
}

// Same shape as TaskSubmission (one file, resubmitting overwrites), but for
// a student submitting an assignment against a GradeItem rather than a TA
// submitting a Task deliverable.
model AssignmentSubmission {
  id          String       @id @default(cuid())
  gradeItemId String
  studentId   String
  fileId      String       @unique
  note        String?      @db.Text
  submittedAt DateTime     @default(now())
  gradeItem   GradeItem    @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  student     User         @relation("AssignmentSubmitter", fields: [studentId], references: [id], onDelete: Cascade)
  file        UploadedFile @relation("AssignmentSubmissionFile", fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([gradeItemId, studentId])
}

model GradeChangeLog {
  id            String      @id @default(cuid())
  gradeRecordId String
  changedById   String
  oldScore      Decimal?    @db.Decimal(6, 2)
  newScore      Decimal?    @db.Decimal(6, 2)
  oldStatus     String?
  newStatus     String?
  reason        String?     @db.Text
  createdAt     DateTime    @default(now())
  gradeRecord   GradeRecord @relation(fields: [gradeRecordId], references: [id], onDelete: Cascade)
  changedBy     User        @relation("GradeChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([gradeRecordId, createdAt])
  @@index([changedById])
}

model GradeImportBatch {
  id               String            @id @default(cuid())
  courseOfferingId String
  importedById     String
  format           ExportFormat
  status           GradeImportStatus @default(QUEUED)
  totalRows        Int               @default(0)
  acceptedRows     Int               @default(0)
  rejectedRows     Int               @default(0)
  errorReport      Json?
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  courseOffering   CourseOffering    @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  importedBy       User              @relation(fields: [importedById], references: [id], onDelete: Restrict)

  @@index([courseOfferingId, createdAt])
}

model ExportJob {
  id               String          @id @default(cuid())
  courseOfferingId String?
  requestedById    String
  exportType       String
  format           ExportFormat
  status           ExportStatus    @default(QUEUED)
  filtersJson      Json?
  fileKey          String?
  errorMessage     String?         @db.Text
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  courseOffering   CourseOffering? @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  requestedBy      User            @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([requestedById, createdAt])
}

model CertificateTemplate {
  id           String          @id @default(cuid())
  name         String
  role         CertificateRole
  locale       String          @default("fa-IR")
  fileId       String?         @unique
  bodySchema   Json
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  file         UploadedFile?   @relation("CertificateTemplateFile", fields: [fileId], references: [id], onDelete: SetNull)
  certificates TACertificate[]

  @@index([role, isActive])
}

model CertificateRequest {
  id                  String                   @id @default(cuid())
  userId              String
  courseOfferingId    String
  role                CertificateRole
  status              CertificateRequestStatus @default(DRAFT)
  professorApproverId String?
  educationApproverId String?
  professorApprovedAt DateTime?
  educationApprovedAt DateTime?
  rejectionReason     String?                  @db.Text
  requestedAt         DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  requester           User                     @relation("CertificateRequester", fields: [userId], references: [id], onDelete: Cascade)
  courseOffering      CourseOffering           @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  professorApprover   User?                    @relation("CertificateProfessorApprover", fields: [professorApproverId], references: [id], onDelete: SetNull)
  educationApprover   User?                    @relation("CertificateEducationApprover", fields: [educationApproverId], references: [id], onDelete: SetNull)
  certificate         TACertificate?

  // Blocking uniqueness only applies while a request is in flight (a raw-SQL
  // partial unique index, WHERE status IN ('DRAFT','SUBMITTED',
  // 'PROFESSOR_APPROVED','EDUCATION_APPROVED','ISSUED')), so a REJECTED or
  // REVOKED request doesn't permanently block a fresh one for the same
  // user/course/role — each attempt becomes its own row instead of being
  // silently reset.
  @@index([userId, courseOfferingId, role])
  @@index([courseOfferingId, status])
}

model TACertificate {
  id                    String               @id @default(cuid())
  certificateRequestId  String               @unique
  templateId            String?
  trackingCode          String               @unique
  verificationTokenHash String               @unique
  pdfFileId             String?              @unique
  issuedAt              DateTime             @default(now())
  revokedAt             DateTime?
  revokedById           String?
  revokeReason          String?              @db.Text
  request               CertificateRequest   @relation(fields: [certificateRequestId], references: [id], onDelete: Cascade)
  template              CertificateTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  pdfFile               UploadedFile?        @relation("CertificatePdfFile", fields: [pdfFileId], references: [id], onDelete: SetNull)
  revokedBy             User?                @relation("CertificateRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)
}

model AvailabilityPoll {
  id               String         @id @default(cuid())
  courseOfferingId String
  createdById      String
  title            String
  description      String?        @db.Text
  pollType         PollType
  deadline         DateTime
  isAnonymous      Boolean        @default(false)
  status           PollStatus     @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User           @relation("PollCreator", fields: [createdById], references: [id], onDelete: Restrict)
  options          PollOption[]
  votes            PollVote[]

  @@index([courseOfferingId, status])
}

model PollOption {
  id         String           @id @default(cuid())
  pollId     String
  label      String
  startsAt   DateTime?
  endsAt     DateTime?
  orderIndex Int              @default(0)
  poll       AvailabilityPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes      PollVote[]

  @@index([pollId, orderIndex])
}

model PollVote {
  id             String           @id @default(cuid())
  pollId         String
  optionId       String
  voterId        String?
  respondentHash String?
  createdAt      DateTime         @default(now())
  poll           AvailabilityPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option         PollOption       @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter          User?            @relation(fields: [voterId], references: [id], onDelete: SetNull)

  // Dedupes identified (non-anonymous) votes. Anonymous votes store
  // voterId: null, so this constraint can't dedupe them (Postgres treats
  // NULL as distinct) — a partial unique index on respondentHash, added
  // in a raw-SQL migration, covers that case instead.
  @@unique([pollId, voterId])
  @@index([optionId])
}

model MessageThread {
  id               String                     @id @default(cuid())
  courseOfferingId String?
  createdById      String
  type             MessageThreadType
  subject          String
  isClosed         Boolean                    @default(false)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  courseOffering   CourseOffering?            @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User                       @relation("ThreadCreator", fields: [createdById], references: [id], onDelete: Restrict)
  participants     MessageThreadParticipant[]
  messages         Message[]

  @@index([courseOfferingId, updatedAt])
}

model MessageThreadParticipant {
  id         String        @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime?
  mutedAt    DateTime?
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model Message {
  id        String        @id @default(cuid())
  threadId  String
  senderId  String
  body      String        @db.Text
  status    MessageStatus @default(SENT)
  createdAt DateTime      @default(now())
  editedAt  DateTime?
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([threadId, createdAt])
  @@index([senderId])
}

model Survey {
  id               String           @id @default(cuid())
  courseOfferingId String
  createdById      String
  title            String
  description      String?          @db.Text
  type             SurveyType
  isAnonymous      Boolean          @default(true)
  minResponses     Int              @default(5)
  opensAt          DateTime
  closesAt         DateTime
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  courseOffering   CourseOffering   @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User             @relation("SurveyCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questions        SurveyQuestion[]
  answers          SurveyAnswer[]

  @@index([courseOfferingId, type])
}

model SurveyQuestion {
  id          String         @id @default(cuid())
  surveyId    String
  text        String
  type        QuestionType
  required    Boolean        @default(true)
  orderIndex  Int            @default(0)
  optionsJson Json?
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers     SurveyAnswer[]

  @@index([surveyId, orderIndex])
}

model SurveyAnswer {
  id             String         @id @default(cuid())
  surveyId       String
  questionId     String
  respondentId   String?
  respondentHash String?
  valueJson      Json
  createdAt      DateTime       @default(now())
  survey         Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question       SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  respondent     User?          @relation(fields: [respondentId], references: [id], onDelete: SetNull)

  @@unique([surveyId, questionId, respondentHash])
  @@index([surveyId, respondentHash])
  @@index([questionId])
}

model ProfessorEvaluation {
  id               String         @id @default(cuid())
  courseOfferingId String
  studentId        String?
  respondentHash   String?
  ratingTeaching   Int
  ratingFairness   Int
  ratingResources  Int
  comment          String?        @db.Text
  createdAt        DateTime       @default(now())
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  student          User?          @relation("ProfessorEvaluationStudent", fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([courseOfferingId, respondentHash])
  @@index([courseOfferingId])
}

model TAEvaluation {
  id                 String         @id @default(cuid())
  courseOfferingId   String
  taUserId           String
  studentId          String?
  respondentHash     String?
  ratingKnowledge    Int
  ratingExplanation  Int
  ratingAvailability Int
  ratingFairness     Int
  comment            String?        @db.Text
  createdAt          DateTime       @default(now())
  courseOffering     CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  student            User?          @relation("TAEvaluationStudent", fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([courseOfferingId, taUserId, respondentHash])
  @@index([courseOfferingId, taUserId])
}

model Announcement {
  id               String          @id @default(cuid())
  departmentId     String?
  courseOfferingId String?
  createdById      String
  title            String
  body             String          @db.Text
  priority         String          @default("normal")
  publishedAt      DateTime?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  department       Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  courseOffering   CourseOffering? @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User            @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([courseOfferingId, publishedAt])
  @@index([departmentId, publishedAt])
}

model AcademicCalendarEvent {
  id               String          @id @default(cuid())
  departmentId     String?
  semesterId       String?
  courseOfferingId String?
  createdById      String
  title            String
  description      String?         @db.Text
  startsAt         DateTime
  endsAt           DateTime?
  eventType        String
  isImportant      Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  department       Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  semester         Semester?       @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  courseOffering   CourseOffering? @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User            @relation("AcademicEventCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([startsAt])
}

model Task {
  id               String           @id @default(cuid())
  courseOfferingId String
  createdById      String
  assigneeId       String?
  title            String
  description      String?          @db.Text
  status           TaskStatus       @default(TODO)
  estimatedMinutes Int?
  dueAt            DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  courseOffering   CourseOffering   @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdBy        User             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee         User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  submissions      TaskSubmission[]

  @@index([courseOfferingId, status])
  @@index([assigneeId, status])
}

// One active submission per task/user; resubmitting overwrites the same row
// since only the latest deliverable matters (no revoke/reassign history like
// CourseRoleAssignment needs).
model TaskSubmission {
  id          String       @id @default(cuid())
  taskId      String
  userId      String
  fileId      String       @unique
  note        String?      @db.Text
  submittedAt DateTime     @default(now())
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation("TaskSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  file        UploadedFile @relation("TaskSubmissionFile", fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([taskId, userId])
}

model ActivityReport {
  id               String         @id @default(cuid())
  courseOfferingId String
  userId           String
  weekStartsAt     DateTime
  summary          String         @db.Text
  hoursSpent       Decimal?       @db.Decimal(5, 2)
  metricsJson      Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseOfferingId, userId, weekStartsAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?          @db.Text
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model AuditLog {
  id               String      @id @default(cuid())
  actorId          String?
  action           AuditAction
  entityType       String
  entityId         String?
  courseOfferingId String?
  ipAddress        String?
  userAgent        String?
  beforeJson       Json?
  afterJson        Json?
  metadata         Json?
  createdAt        DateTime    @default(now())
  actor            User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([courseOfferingId, createdAt])
}

model SecurityEvent {
  id        String            @id @default(cuid())
  userId    String?
  type      SecurityEventType
  severity  String            @default("info")
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime          @default(now())
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}
